{$DOMAIN} {
    # API and WebSocket routes -> FastAPI
    handle /auth/* {
        reverse_proxy fastapi:8000
    }

    handle /games/* {
        reverse_proxy fastapi:8000
    }

    handle /ws/* {
        reverse_proxy fastapi:8000
    }

    # Everything else -> static files (SPA)
    handle {
        root * /srv/web
        try_files {path} /index.html
        file_server
    }
}
