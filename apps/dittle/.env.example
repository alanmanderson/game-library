# Dittle environment variables.
# Dittle keeps all game state in memory, so it needs no database.

# Port the server listens on. Defaults to 3000 for local dev; the container
# runs on 8080 (Express convention) via docker-compose.
PORT=3000

# Centralized logging service (shared across all games). Left blank locally,
# injected by infra/docker-compose.yml in production.
LOG_SERVICE_URL=
LOG_SERVICE_API_KEY=
