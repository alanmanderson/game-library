# Shared Postgres
POSTGRES_PASSWORD=changeme

# Per-game database URLs (all share the same Postgres instance, separate databases)
AI_PINOCHLE_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/ai_pinochle
BACKGAMMON_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/backgammon
BUGHOUSE_DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/bughouse

# Google OAuth (shared across games)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT secret (shared across games for cross-game auth)
JWT_SECRET=changeme

# Logging service
LOG_SERVICE_API_KEY=changeme

# Game-specific settings
# AI_PINOCHLE_REDIS_URL=redis://redis:6379  # Optional: enable for multi-instance WebSocket fan-out
